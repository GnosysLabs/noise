# Leave this file absent for local shard storage under /var/lib/noise-relay.
#
# To use an S3-compatible bucket, copy this file to
# /etc/noise-relay/storage.env, make it root-readable only, and fill in:
NOISE_STORAGE_BACKEND=s3
NOISE_S3_BUCKET=noise-relay-example
NOISE_S3_PREFIX=noise-relay
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional for Cloudflare R2, Backblaze B2, MinIO, or another S3-compatible
# provider. HTTPS is required by default.
# AWS_ENDPOINT_URL_S3=https://example.r2.cloudflarestorage.com

# Optional application quota in bytes. Zero or absent means the disk or bucket
# itself is the limit.
# NOISE_STORAGE_LIMIT_BYTES=1099511627776
